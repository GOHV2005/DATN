        c\u1EE7a m\xECnh.  "
      objectReference: {fileID: 0}
    - target: {fileID: 5077426962020374511, guid: c105abecc8ebe7c4e9d0a4894e6428ef,
        type: 3}
      propertyPath: completeDialogue.lines.Array.data[0].text
      value: "Ng\u01B0\u01A1i t\xECm \u0111\u01B0\u1EE3c ng\xE0i \u1EA5y ch\u01B0a?"
      objectReference: {fileID: 0}
    - target: {fileID: 5077426962020374511, guid: c105abecc8ebe7c4e9d0a4894e6428ef,
        type: 3}
      propertyPath: completeDialogue.lines.Array.data[1].text
      value: "T\xF4i th\u1EA5y th\u1EE9 n\xE0y b\xEAn c\u1EA1nh m\u1ED9t ng\u01B0\u1EDDi
        c\xF3 th\u1EC3 l\xE0 ng\xE0i Wushu"
      objectReference: {fileID: 0}
    - target: {fileID: 5077426962020374511, guid: c105abecc8ebe7c4e9d0a4894e6428ef,
        type: 3}
      propertyPath: completeDialogue.lines.Array.data[2].text
      value: "\u0110\xE2y l\xE0....*r\u01B0ng r\u01B0ng n\u01B0\u1EDBc m\u1EAFt"
      objectReference: {fileID: 0}
    - target: {fileID: 5077426962020374511, guid: c105abecc8ebe7c4e9d0a4894e6428ef,
        type: 3}
      propertyPath: completeDialogue.lines.Array.data[3].text
      value: "C\xF3 l\u1EBD ng\xE0i \u1EA5y \u0111\xE3 ho\xE0n th\xE0nh s\u1EE9 m\u1EC7nh
        c\u1EE7a m\xECnh.  "
      objectReference: {fileID: 0}
    - target: {fileID: 5077426962020374511, guid: c105abecc8ebe7c4e9d0a4894e6428ef,
        type: 3}
      propertyPath: completeDialogue.lines.Array.data[4].text
