      propertyPath: questDialogue.lines.Array.size
      value: 5
      objectReference: {fileID: 0}
    - target: {fileID: 5077426962020374511, guid: c105abecc8ebe7c4e9d0a4894e6428ef,
        type: 3}
      propertyPath: comebackDialogue.lines.Array.size
      value: 2
      objectReference: {fileID: 0}
    - target: {fileID: 5077426962020374511, guid: c105abecc8ebe7c4e9d0a4894e6428ef,
        type: 3}
      propertyPath: completeDialogue.lines.Array.size
      value: 3
      objectReference: {fileID: 0}
    - target: {fileID: 5077426962020374511, guid: c105abecc8ebe7c4e9d0a4894e6428ef,
        type: 3}
      propertyPath: missingItemDialogue.lines.Array.size
      value: 1
      objectReference: {fileID: 0}
    - target: {fileID: 5077426962020374511, guid: c105abecc8ebe7c4e9d0a4894e6428ef,
        type: 3}
      propertyPath: questDialogue.lines.Array.data[0].text
      value: "Oh ai \u0111\xE2y?"
      objectReference: {fileID: 0}
    - target: {fileID: 5077426962020374511, guid: c105abecc8ebe7c4e9d0a4894e6428ef,
        type: 3}
      propertyPath: questDialogue.lines.Array.data[1].text
      value: "Ch\xE0o b\xE1c t\xF4i l\xE0 D\u1EBF M\xE8n b\u1ECB l\u1EA1c xu\u1ED1ng
        n\u01A1i \u0111\xE2y do ph\xEDa tr\xEAn \u0111\xE3 b\u1ECB ch\u1EB7n b\u1EDFi
        \u0111\xE1"
      objectReference: {fileID: 0}
    - target: {fileID: 5077426962020374511, guid: c105abecc8ebe7c4e9d0a4894e6428ef,
        type: 3}
      propertyPath: questDialogue.lines.Array.data[2].text
      value: "V\u1EADy ng\u01B0\u01A1i mu\u1ED1n ta r\xE8n ra th\u1EE9 g\xEC \u0111\xF3
        \u0111\u1EC3 gi\u1EA3i quy\u1EBFt v\u1EA5n \u0111\u1EC1?"
      objectReference: {fileID: 0}
    - target: {fileID: 5077426962020374511, guid: c105abecc8ebe7c4e9d0a4894e6428ef,
        type: 3}
      propertyPath: questDialogue.lines.Array.data[3].text
      value: "\u0110\xFAng v\u1EADy "
      objectReference: {fileID: 0}
    - target: {fileID: 5077426962020374511, guid: c105abecc8ebe7c4e9d0a4894e6428ef,
        type: 3}
      propertyPath: questDialogue.lines.Array.data[4].text
      value: "Hmm ng\u01B0\u01A1i ph\u1EA3i cho ta th\u1EA5y ng\u01B0\u01A1i c\xF3
        x\u1EE9ng \u0111\xE1ng \u0111\u1EC3 ta r\xE8n c\xE2y c\xFAp cho ng\u01B0\u01A1i
        kh\xF4ng"
      objectReference: {fileID: 0}
    - target: {fileID: 5077426962020374511, guid: c105abecc8ebe7c4e9d0a4894e6428ef,
        type: 3}
      propertyPath: questDialogue.lines.Array.data[5].text
      value: "C\xE1i n\xE0y \u0111\u01B0\u1EE3c kh\xF4ng?"
      objectReference: {fileID: 0}
    - target: {fileID: 5077426962020374511, guid: c105abecc8ebe7c4e9d0a4894e6428ef,
        type: 3}
      propertyPath: comebackDialogue.lines.Array.data[0].text
      value: "C\xFAp c\u1EE7a ta nh\u01B0 th\u1EBF n\xE0o?"
      objectReference: {fileID: 0}
    - target: {fileID: 5077426962020374511, guid: c105abecc8ebe7c4e9d0a4894e6428ef,
        type: 3}
      propertyPath: comebackDialogue.lines.Array.data[1].text
      value: "R\u1EA5t tuy\u1EC7t!"
      objectReference: {fileID: 0}
    - target: {fileID: 5077426962020374511, guid: c105abecc8ebe7c4e9d0a4894e6428ef,
        type: 3}
      propertyPath: completeDialogue.lines.Array.data[0].text
      value: "Ohhh~Gi\u1EA5y khen ch\xE1u ngoan b\xE1c H\u1ED3 \xE0"
      objectReference: {fileID: 0}
    - target: {fileID: 5077426962020374511, guid: c105abecc8ebe7c4e9d0a4894e6428ef,
        type: 3}
      propertyPath: completeDialogue.lines.Array.data[1].text
      value: "\u0110\u01B0\u1EE3c \u0111\u1EA5y ta s\u1EBD r\xE8n cho ng\u01B0\u01A1i
        c\xE2y c\xFAp, \u0111\u1EE3i ta m\u1ED9t ch\xFAt "
      objectReference: {fileID: 0}
    - target: {fileID: 5077426962020374511, guid: c105abecc8ebe7c4e9d0a4894e6428ef,
        type: 3}
      propertyPath: completeDialogue.lines.Array.data[2].text
      value: "H\xE3y d\xF9ng th\u1EE9 n\xE0y \u0111\u1EC3 m\u1EDF l\u1ED1i \u0111i
        c\u1EE7a ng\u01B0\u01A1i \u0111i"
      objectReference: {fileID: 0}
    - target: {fileID: 5077426962020374511, guid: c105abecc8ebe7c4e9d0a4894e6428ef,
        type: 3}
      propertyPath: questDialogue.lines.Array.data[0].isPlayer
