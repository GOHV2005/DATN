        cho \xF4ng 1 c\xE1i j \u0111\xF3 b\u1ECF b\u1EE5ng \u0111\u01B0\u1EE3c kh\xF4ng"
      objectReference: {fileID: 0}
    - target: {fileID: 5077426962020374511, guid: c105abecc8ebe7c4e9d0a4894e6428ef,
        type: 3}
      propertyPath: fullDialogue.lines.Array.data[4].text
      value: "C\u1EA3m \u01A1n ch\xE1u r\u1EA5t nhi\u1EC1u ch\xFAc may m\u1EAFn"
      objectReference: {fileID: 0}
    - target: {fileID: 5077426962020374511, guid: c105abecc8ebe7c4e9d0a4894e6428ef,
        type: 3}
      propertyPath: fullDialogue.lines.Array.data[5].text
      value: "T\xF9y ch\xE1u ch\u1EAFc l\xE0 kh\xF4ng c\xF3 c\xFAp c\u1EE7a \xF4ng
        th\xEC ch\xE1u kh\xF4ng c\xF3 th\u1EC3 v\u01B0\u1EE3c qua t\u1EA3ng \u0111\xE1
        \u0111\xF3 \u0111\xE2u"
