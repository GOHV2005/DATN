      propertyPath: 'requiredAmounts.Array.data[0]'
      value: 1
      objectReference: {fileID: 0}
    - target: {fileID: 5077426962020374511, guid: c105abecc8ebe7c4e9d0a4894e6428ef,
        type: 3}
      propertyPath: questDialogue.lines.Array.size
      value: 12
      objectReference: {fileID: 0}
    - target: {fileID: 5077426962020374511, guid: c105abecc8ebe7c4e9d0a4894e6428ef,
        type: 3}
      propertyPath: comebackDialogue.lines.Array.size
      value: 1
      objectReference: {fileID: 0}
    - target: {fileID: 5077426962020374511, guid: c105abecc8ebe7c4e9d0a4894e6428ef,
        type: 3}
      propertyPath: completeDialogue.lines.Array.size
      value: 5
      objectReference: {fileID: 0}
    - target: {fileID: 5077426962020374511, guid: c105abecc8ebe7c4e9d0a4894e6428ef,
        type: 3}
      propertyPath: fullDialogue.lines.Array.data[0].text
      value: "Ng\u01B0\u01A1i l\xE0 ai ?"
      objectReference: {fileID: 0}
    - target: {fileID: 5077426962020374511, guid: c105abecc8ebe7c4e9d0a4894e6428ef,
        type: 3}
      propertyPath: fullDialogue.lines.Array.data[1].text
      value: "Ta l\xE0 d\u1EBF m\xE8n t\u1EEB khu r\u1EEBng ph\xEDa t\xE2y \u0111i
        \u0111\u1EBFn \u0111\xE2y. C\xF2n ng\u01B0\u01A1i l\xE0?"
      objectReference: {fileID: 0}
    - target: {fileID: 5077426962020374511, guid: c105abecc8ebe7c4e9d0a4894e6428ef,
        type: 3}
      propertyPath: fullDialogue.lines.Array.data[2].text
      value: "V\u1EADy sao ta l\xE0 l\xEDnh canh c\xF3 nhi\u1EC7m v\u1EE5 tu\u1EA7n
        tra \u1EDF khu v\u1EF1c n\xE0y. Th\u1EBF ng\u01B0\u01A1i \u0111\u1EBFn \u0111\xE2y
        l\xE0m g\xEC?"
      objectReference: {fileID: 0}
    - target: {fileID: 5077426962020374511, guid: c105abecc8ebe7c4e9d0a4894e6428ef,
        type: 3}
      propertyPath: fullDialogue.lines.Array.data[3].text
      value: "Ta \u0111\u1EBFn \u0111\xE2y \u0111\u1EC3 gi\u1EA3i c\u1EE9u ng\u01B0\u1EDDi
        b\u1EA1n c\u1EE7a ta \u0111ang b\u1ECB b\u1EAFt \u1EDF v\u01B0\u01A1ng qu\u1ED1c
        ki\u1EBFn"
      objectReference: {fileID: 0}
    - target: {fileID: 5077426962020374511, guid: c105abecc8ebe7c4e9d0a4894e6428ef,
        type: 3}
      propertyPath: fullDialogue.lines.Array.data[4].text
      value: "V\u1EADy sao t\xECnh b\u1EA1n thi\xEAn li\xEAn ph\u1EBFt nh\u1EDD"
      objectReference: {fileID: 0}
    - target: {fileID: 5077426962020374511, guid: c105abecc8ebe7c4e9d0a4894e6428ef,
        type: 3}
      propertyPath: fullDialogue.lines.Array.data[5].text
      value: "C\xE1i con \u0111\u01B0\u1EDDng gi\u1EA3i c\u1EE9u t\xECnh b\u1EA1n
        c\u1EE7a ng\u01B0\u01A1i b\u1ECB ch\u1EB7n r\u1ED3i"
      objectReference: {fileID: 0}
    - target: {fileID: 5077426962020374511, guid: c105abecc8ebe7c4e9d0a4894e6428ef,
        type: 3}
      propertyPath: fullDialogue.lines.Array.data[6].text
      value: "b\u1ECB ch\u1EB7n \xFD ng\u01B0\u01A1i l\xE0 sao?"
      objectReference: {fileID: 0}
    - target: {fileID: 5077426962020374511, guid: c105abecc8ebe7c4e9d0a4894e6428ef,
        type: 3}
      propertyPath: fullDialogue.lines.Array.data[7].text
      value: "\u0110\xFAng v\u1EADy n\xF3 b\u1ECB 1 c\xE1i d\xE2y leo r\u1EA5t to
        m\u1ECDc ch\u1EB7n \u0111\u01B0\u1EDDng r\u1ED3i kh\xF4ng th\u1EC3 \u0111i
        qua \u0111c"
      objectReference: {fileID: 0}
    - target: {fileID: 5077426962020374511, guid: c105abecc8ebe7c4e9d0a4894e6428ef,
        type: 3}
      propertyPath: fullDialogue.lines.Array.data[8].text
      value: "Th\u1EBF c\xF3 c\xE1ch n\xE0o kh\xF4ng?"
      objectReference: {fileID: 0}
    - target: {fileID: 5077426962020374511, guid: c105abecc8ebe7c4e9d0a4894e6428ef,
        type: 3}
      propertyPath: fullDialogue.lines.Array.data[9].text
      value: "C\xF3 1 c\xE1ch"
      objectReference: {fileID: 0}
    - target: {fileID: 5077426962020374511, guid: c105abecc8ebe7c4e9d0a4894e6428ef,
        type: 3}
      propertyPath: fullDialogue.lines.Array.data[10].text
      value: "C\xE1ch g\xEC?"
      objectReference: {fileID: 0}
    - target: {fileID: 5077426962020374511, guid: c105abecc8ebe7c4e9d0a4894e6428ef,
        type: 3}
      propertyPath: fullDialogue.lines.Array.data[11].text
      value: "\u1EDE ph\xEDa \u0111\xF4ng c\xF3 1 con b\u1ECD hung d\xF2ng m\xE1u
        c\u1EE7a n\xF3 li\xEAn k\u1EBFt v\u1EDBi v\u1EDBi \u0111\u1ED1ng d\xE2y leo."
      objectReference: {fileID: 0}
    - target: {fileID: 5077426962020374511, guid: c105abecc8ebe7c4e9d0a4894e6428ef,
        type: 3}
      propertyPath: fullDialogue.lines.Array.data[12].text
      value: "N\u1EBFu ng\u01B0\u01A1i gi\u1EBFt \u0111\u01B0\u1EE3c n\xF3 th\xEC
        \u0111\u1ED1ng d\xE2y leo \u0111\xF3 s\u1EBD \u0111c gi\u1EA3i tr\u1EEB "
      objectReference: {fileID: 0}
    - target: {fileID: 5077426962020374511, guid: c105abecc8ebe7c4e9d0a4894e6428ef,
        type: 3}
      propertyPath: fullDialogue.lines.Array.data[13].text
      value: "Nh\u01B0ng con b\u1ECD hung n\xE0y t\xEDnh kh\xED n\xF3ng n\u1EA3y
        lu\xF4n h\xFAc \u0111\u1EA7u v\xE0o m\u1ECDi th\u1EE9."
      objectReference: {fileID: 0}
    - target: {fileID: 5077426962020374511, guid: c105abecc8ebe7c4e9d0a4894e6428ef,
        type: 3}
      propertyPath: fullDialogue.lines.Array.data[14].text
      value: " N\xEAn l\xE0 khi n\xF3 h\xFAt \u0111\u1ED5 c\xE1i c\xE2y th\xEC \u0111\u1ED3ng
        th\u1EDDi \u0111\xE1 r\u01A1i l\u1EA5p h\u1EBFt mi\u1EC7n han r\u1ED3i"
      objectReference: {fileID: 0}
    - target: {fileID: 5077426962020374511, guid: c105abecc8ebe7c4e9d0a4894e6428ef,
        type: 3}
      propertyPath: fullDialogue.lines.Array.data[15].text
      value: "\xC2y da kh\xF3 r\u1ED3i \u0111\xE2y"
      objectReference: {fileID: 0}
    - target: {fileID: 5077426962020374511, guid: c105abecc8ebe7c4e9d0a4894e6428ef,
        type: 3}
      propertyPath: fullDialogue.lines.Array.data[16].text
      value: "Nh\u01B0ng \u1EDF d\u01B0\u1EDBi kia c\xF3 1 \xF4ng th\u1EE3 r\xE8n
        l\xE0n qu\u1EA3n quanh \u0111\xE2y \u0111\u1EC3 t\xECm nguy\xEAn li\u1EC7u."
      objectReference: {fileID: 0}
    - target: {fileID: 5077426962020374511, guid: c105abecc8ebe7c4e9d0a4894e6428ef,
        type: 3}
      propertyPath: fullDialogue.lines.Array.data[17].text
      value: "Ng\u01B0\u01A1i c\xF3 th\u1EC3 nh\u1EDD \u1ED5ng ch\u1EBF t\u1EA1o
        c\xFAp \u0111\u1EC3 \u0111\xE0o \u0111\u1ED1ng \u0111\xE1 \u0111\xF3 ra."
      objectReference: {fileID: 0}
    - target: {fileID: 5077426962020374511, guid: c105abecc8ebe7c4e9d0a4894e6428ef,
        type: 3}
      propertyPath: fullDialogue.lines.Array.data[18].text
      value: "\xD4 c\u1EA3n \u01A1n nh\xE1"
      objectReference: {fileID: 0}
    - target: {fileID: 5077426962020374511, guid: c105abecc8ebe7c4e9d0a4894e6428ef,
        type: 3}
      propertyPath: fullDialogue.lines.Array.data[19].text
      value: "Kh\xF4ng c\xF3 g\xEC"
      objectReference: {fileID: 0}
    - target: {fileID: 5077426962020374511, guid: c105abecc8ebe7c4e9d0a4894e6428ef,
        type: 3}
      propertyPath: fullDialogue.lines.Array.data[20].text
      value: "\u0110i \u0111\u01B0\u1EDDng c\u1EA9n th\u1EADn"
      objectReference: {fileID: 0}
    - target: {fileID: 5077426962020374511, guid: c105abecc8ebe7c4e9d0a4894e6428ef,
        type: 3}
      propertyPath: fullDialogue.lines.Array.data[21].text
      value: "\u0110i \u0111\u01B0\u1EDDng c\u1EA9n th\u1EADn"
      objectReference: {fileID: 0}
    - target: {fileID: 5077426962020374511, guid: c105abecc8ebe7c4e9d0a4894e6428ef,
        type: 3}
      propertyPath: questDialogue.lines.Array.data[0].text
      value: "Xin ch\xE0o! \xF4ng l\xE0 ai v\xE0 \u1EDF \u0111\xE2y l\xE0m g\xEC
        v\u1EADy"
      objectReference: {fileID: 0}
    - target: {fileID: 5077426962020374511, guid: c105abecc8ebe7c4e9d0a4894e6428ef,
        type: 3}
      propertyPath: questDialogue.lines.Array.data[1].text
      value: "Ta l\xE0 Pug ng\u01B0\u1EDDi ph\u1EE5 t\xF9ng c\u1EE7a Th\u01B0\u01A1ng
        s\u0129 Wushu "
      objectReference: {fileID: 0}
    - target: {fileID: 5077426962020374511, guid: c105abecc8ebe7c4e9d0a4894e6428ef,
        type: 3}
      propertyPath: questDialogue.lines.Array.data[2].text
      value: "M\xE0 ng\u01B0\u01A1i l\xE0 ai \u1EA5y nh\u1EC9?"
      objectReference: {fileID: 0}
    - target: {fileID: 5077426962020374511, guid: c105abecc8ebe7c4e9d0a4894e6428ef,
        type: 3}
      propertyPath: questDialogue.lines.Array.data[3].text
      value: "T\xF4i l\xE0 D\u1EBF M\xE8n \u0111ang tr\xEAn \u0111\u01B0\u1EDDng
        gi\u1EA3i c\u1EE9u b\u1EA1n c\u1EE7a m\xECnh kh\u1ECFi ki\u1EBFn \u0111en"
      objectReference: {fileID: 0}
    - target: {fileID: 5077426962020374511, guid: c105abecc8ebe7c4e9d0a4894e6428ef,
        type: 3}
      propertyPath: questDialogue.lines.Array.data[4].text
      value: "ra l\xE0 v\u1EADy..."
      objectReference: {fileID: 0}
    - target: {fileID: 5077426962020374511, guid: c105abecc8ebe7c4e9d0a4894e6428ef,
        type: 3}
      propertyPath: questDialogue.lines.Array.data[5].text
      value: "Th\u1EBF ng\xE0i Wushu, \xF4ng \u1EA5y \u0111\xE2u?"
      objectReference: {fileID: 0}
    - target: {fileID: 5077426962020374511, guid: c105abecc8ebe7c4e9d0a4894e6428ef,
        type: 3}
      propertyPath: questDialogue.lines.Array.data[6].text
      value: "Ta \u0111\xE3 l\u1EA1c m\u1EA5t ng\xE0i \u1EA5y trong qu\xE1 tr\xECnh
        ch\u1EA1y tr\u1ED1n kh\u1ECFi B\u1ECD hung kh\u1ED5ng l\u1ED3"
      objectReference: {fileID: 0}
    - target: {fileID: 5077426962020374511, guid: c105abecc8ebe7c4e9d0a4894e6428ef,
        type: 3}
      propertyPath: questDialogue.lines.Array.data[7].text
      value: "Ta th\u1EF1c s\u1EF1 c\u1EA7n t\xECm ng\xE0i \u1EA5y, ng\u01B0\u01A1i
        c\xF3 th\u1EC3 gi\xFAp ta \u0111\u01B0\u1EE3c ch\u1EE9"
      objectReference: {fileID: 0}
    - target: {fileID: 5077426962020374511, guid: c105abecc8ebe7c4e9d0a4894e6428ef,
        type: 3}
      propertyPath: questDialogue.lines.Array.data[8].text
      value: "\u0110\u01B0\u1EE3c th\xF4i nh\u01B0ng h\xE3y cho t\xF4i manh m\u1ED1i
        v\u1EC1 ki\u1EBFn ch\xFAa"
      objectReference: {fileID: 0}
    - target: {fileID: 5077426962020374511, guid: c105abecc8ebe7c4e9d0a4894e6428ef,
        type: 3}
      propertyPath: questDialogue.lines.Array.data[9].text
      value: "Ng\u01B0\u01A1i t\xECm \u0111\u01B0\u1EE3c ng\xE0i \u1EA5y th\xEC ta
        s\u1EBD trao \u0111\u1ED5i th\xF4ng tin v\u1EDBi ng\u01B0\u01A1i"
      objectReference: {fileID: 0}
    - target: {fileID: 5077426962020374511, guid: c105abecc8ebe7c4e9d0a4894e6428ef,
        type: 3}
      propertyPath: questDialogue.lines.Array.data[10].text
      value: "\u0110\u01B0\u1EE3c v\u1EADy \u0111\u1EE3i \u1EDF \u0111\xE2y nh\xE9"
      objectReference: {fileID: 0}
    - target: {fileID: 5077426962020374511, guid: c105abecc8ebe7c4e9d0a4894e6428ef,
        type: 3}
      propertyPath: questDialogue.lines.Array.data[11].text
      value: "\u0110i c\u1EA9n th\u1EADn"
      objectReference: {fileID: 0}
    - target: {fileID: 5077426962020374511, guid: c105abecc8ebe7c4e9d0a4894e6428ef,
        type: 3}
      propertyPath: questDialogue.lines.Array.data[12].text
