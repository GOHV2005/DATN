      objectReference: {fileID: 0}
    - target: {fileID: 5077426962020374511, guid: c105abecc8ebe7c4e9d0a4894e6428ef,
        type: 3}
      propertyPath: fullDialogue.playerSprite
      value: 
      objectReference: {fileID: -7689763433968391079, guid: 05b6eb43be472914381af94b2db7f9b3,
        type: 3}
    - target: {fileID: 5077426962020374511, guid: c105abecc8ebe7c4e9d0a4894e6428ef,
        type: 3}
      propertyPath: fullDialogue.lines.Array.data[1].text
      value: "ch\xE0o ch\xE1u ch\xE1u mu\u1ED1n g\xEC n\xE0o"
      objectReference: {fileID: 0}
    - target: {fileID: 5077426962020374511, guid: c105abecc8ebe7c4e9d0a4894e6428ef,
        type: 3}
      propertyPath: fullDialogue.lines.Array.data[2].text
      value: "ch\xE1u \u0111ang tr\xEAn \u0111\u01B0\u1EDDng gi\u1EA3i c\u1EE9u d\u1EBF
        cho\u1EAFc m\xE0 b\u1ECB 1 h\xF2n \u0111\xE1 c\u1EA3n \u0111\u01B0\u1EDDng
        \xF4ng c\xF3 c\xE1nh n\xE0o gi\u1EA3i quy\u1EBFt \u0111c ko"
      objectReference: {fileID: 0}
    - target: {fileID: 5077426962020374511, guid: c105abecc8ebe7c4e9d0a4894e6428ef,
        type: 3}
      propertyPath: fullDialogue.lines.Array.data[3].text
      value: "Hmmm \xF4ng c\xF3  1  c\xE2y c\xFAp c\u0169 c\xF3 th\u1EC3 gi\xFAp
        ch\xE1u gi\u1EA3i quy\u1EBFt c\u1EE5c \u0111\xE1 \u0111\xF3 nh\u01B0ng m\xE0
        \xF4ng h\u01A1i \u0111\xF3i li\u1EC7u r\u1EB1ng ch\xE1u c\xF3 th\u1EC3 \u0111em
        cho \xF4ng 1 c\xE1i j \u0111\xF3 b\u1ECF b\u1EE5ng \u0111\u01B0\u1EE3c kh\xF4ng"
      objectReference: {fileID: 0}
    - target: {fileID: 5077426962020374511, guid: c105abecc8ebe7c4e9d0a4894e6428ef,
        type: 3}
      propertyPath: fullDialogue.lines.Array.data[4].text
      value: "C\u1EA3m \u01A1n ch\xE1u r\u1EA5t nhi\u1EC1u ch\xFAc may m\u1EAFn"
      objectReference: {fileID: 0}
    - target: {fileID: 5077426962020374511, guid: c105abecc8ebe7c4e9d0a4894e6428ef,
        type: 3}
      propertyPath: fullDialogue.lines.Array.data[5].text
      value: "T\xF9y ch\xE1u ch\u1EAFc l\xE0 kh\xF4ng c\xF3 c\xFAp c\u1EE7a \xF4ng
        th\xEC ch\xE1u kh\xF4ng c\xF3 th\u1EC3 v\u01B0\u1EE3c qua t\u1EA3ng \u0111\xE1
        \u0111\xF3 \u0111\xE2u"
      objectReference: {fileID: 0}
    - target: {fileID: 5077426962020374511, guid: c105abecc8ebe7c4e9d0a4894e6428ef,
        type: 3}
      propertyPath: fullDialogue.lines.Array.data[6].text
      value: "\xD4ng \u0111ang \u0111\xF3i ;-;"
