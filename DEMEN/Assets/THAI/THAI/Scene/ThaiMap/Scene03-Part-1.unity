      objectReference: {fileID: 0}
    - target: {fileID: 5077426962020374511, guid: c105abecc8ebe7c4e9d0a4894e6428ef,
        type: 3}
      propertyPath: questDialogue.lines.Array.data[16].text
      value: "Nh\u01B0 \u0111\xE3 h\u1EE9a c\u1EADu h\xE3y \u0111i th\u1EB3ng xu\u1ED1ng
        r\xECa b\u1EE5i c\xE2y s\u1EBD c\xF3 \u0111\u01B0\u1EDDng xu\u1ED1ng hang
        v\xE0 h\xE3y c\u1EA7m th\u1EE9 n\xE0y, c\xF3 l\u1EBD n\xF3 s\u1EBD gi\xFAp
        \xEDch cho c\u1EADu \u0111\u1EA5y."
      objectReference: {fileID: 0}
    - target: {fileID: 5077426962020374511, guid: c105abecc8ebe7c4e9d0a4894e6428ef,
        type: 3}
      propertyPath: comebackDialogue.lines.Array.data[0].text
      value: "c\u1EA3m \u01A1n c\u1EADu"
      objectReference: {fileID: 0}
    - target: {fileID: 5077426962020374511, guid: c105abecc8ebe7c4e9d0a4894e6428ef,
        type: 3}
      propertyPath: comebackDialogue.lines.Array.data[1].text
      value: "C\xF3 l\u1EBD ng\xE0i \u1EA5y \u0111\xE3 ho\xE0n th\xE0nh s\u1EE9 m\u1EC7nh
        c\u1EE7a m\xECnh.  "
      objectReference: {fileID: 0}
    - target: {fileID: 5077426962020374511, guid: c105abecc8ebe7c4e9d0a4894e6428ef,
        type: 3}
      propertyPath: comebackDialogue.lines.Array.data[2].text
      value: "\u0110\xE2y l\xE0....*r\u01B0ng r\u01B0ng n\u01B0\u1EDBc m\u1EAFt"
      objectReference: {fileID: 0}
    - target: {fileID: 5077426962020374511, guid: c105abecc8ebe7c4e9d0a4894e6428ef,
