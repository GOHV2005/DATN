        type: 3}
      propertyPath: 'requiredItems.Array.data[0]'
      value: "di v\u1EADt"
      objectReference: {fileID: 0}
    - target: {fileID: 5077426962020374511, guid: c105abecc8ebe7c4e9d0a4894e6428ef,
        type: 3}
      propertyPath: fullDialogue.lines.Array.size
      value: 21
      objectReference: {fileID: 0}
    - target: {fileID: 5077426962020374511, guid: c105abecc8ebe7c4e9d0a4894e6428ef,
        type: 3}
      propertyPath: missingItemDialogue.npcSprite
      value: 
      objectReference: {fileID: -855298285791758126, guid: 2bc6f0f4efe9f2b45ab8edd079320133,
