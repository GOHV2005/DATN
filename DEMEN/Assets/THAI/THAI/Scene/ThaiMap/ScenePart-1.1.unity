    - target: {fileID: 5077426962020374511, guid: c105abecc8ebe7c4e9d0a4894e6428ef,
        type: 3}
      propertyPath: fullDialogue.lines.Array.data[2].text
      value: "ch\xE1u \u0111ang tr\xEAn \u0111\u01B0\u1EDDng gi\u1EA3i c\u1EE9u d\u1EBF
        cho\u1EAFc m\xE0 b\u1ECB 1 h\xF2n \u0111\xE1 c\u1EA3n \u0111\u01B0\u1EDDng
