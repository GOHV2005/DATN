    - target: {fileID: 5077426962020374511, guid: c105abecc8ebe7c4e9d0a4894e6428ef,
        type: 3}
      propertyPath: fullDialogue.lines.Array.data[3].text
      value: "Hmmm \xF4ng c\xF3  1  c\xE2y c\xFAp c\u0169 c\xF3 th\u1EC3 gi\xFAp
