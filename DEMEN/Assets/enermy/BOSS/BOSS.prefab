--- !u!114 &2678305495915170704
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 5393454926569549560}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 12d931bccceac0d45a700ece59e32fe7, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  talkTrigger: {fileID: 8721532065983353303}
  introDialogue:
    playerSprite: {fileID: 5945871790718036829, guid: ae04c40ca785d07499f40f828afaf685,
      type: 3}
    npcSprite: {fileID: 3486365374980857469, guid: 723062f81455a4243aeaf0a042f53827,
      type: 3}
    lines:
    - isPlayer: 1
      text: "N\xE0y b\xE0 gi\xE0! Mau th\u1EA3 D\u1EBF Cho\u1EAFt ra!"
      enableCameraFocus: 0
      cameraFocusTarget: {fileID: 0}
    - isPlayer: 0
      text: "B\xC0 GI\xC0!? Ng\u01B0\u01A1i v\u1EEBa g\u1ECDi ai l\xE0 b\xE0 gi\xE0
        h\u1EA3!?"
      enableCameraFocus: 0
      cameraFocusTarget: {fileID: 0}
    - isPlayer: 0
      text: "Ta m\u1EDBi 20 n\u1ED3i b\xE1nh ch\u01B0ng th\xF4i nh\xE9!"
      enableCameraFocus: 0
      cameraFocusTarget: {fileID: 0}
    - isPlayer: 1
      text: "\u1ED2\u2026 xin l\u1ED7i qu\xFD c\xF4."
      enableCameraFocus: 0
      cameraFocusTarget: {fileID: 0}
    - isPlayer: 1
      text: "V\u1EADy th\xEC\u2026 qu\xFD c\xF4 c\xF3 th\u1EC3 th\u1EA3 ng\u01B0\u1EDDi
        b\u1EA1n b\xE9 nh\u1ECF c\u1EE7a t\xF4i ra \u0111\u01B0\u1EE3c kh\xF4ng?"
      enableCameraFocus: 0
      cameraFocusTarget: {fileID: 0}
    - isPlayer: 0
      text: "H\u1EEBm\u2026 nghe c\u0169ng \u0111\u01B0\u1EE3c \u0111\u1EA5y."
      enableCameraFocus: 0
      cameraFocusTarget: {fileID: 0}
    - isPlayer: 0
      text: "Nh\u01B0ng ng\u01B0\u01A1i l\xE0 ai m\xE0 d\xE1m v\xE0o l\xE3nh \u0111\u1ECBa
        c\u1EE7a ta?"
      enableCameraFocus: 0
      cameraFocusTarget: {fileID: 0}
    - isPlayer: 1
      text: "Ta l\xE0 D\u1EBF M\xE8n."
      enableCameraFocus: 0
      cameraFocusTarget: {fileID: 0}
    - isPlayer: 0
      text: "D\u1EBF\u2026 M\xE8n?"
      enableCameraFocus: 0
      cameraFocusTarget: {fileID: 0}
    - isPlayer: 0
      text: "Ta ch\u01B0a t\u1EEBng nghe t\xEAn."
      enableCameraFocus: 0
      cameraFocusTarget: {fileID: 0}
    - isPlayer: 1
      text: "\u0110\u01B0\u01A1ng nhi\xEAn r\u1ED3i."
      enableCameraFocus: 0
      cameraFocusTarget: {fileID: 0}
    - isPlayer: 1
      text: "Ta \u0111\u1EBFn t\u1EEB khu r\u1EEBng ph\xEDa T\xE2y, n\u01A1i m\xE0
        ki\u1EBFn ch\u01B0a d\xE1m b\xE9n m\u1EA3ng"
      enableCameraFocus: 0
      cameraFocusTarget: {fileID: 0}
    - isPlayer: 0
      text: "\u1ED2~ gh\xEA g\u1EDBm nh\u1EC9."
      enableCameraFocus: 0
      cameraFocusTarget: {fileID: 0}
    - isPlayer: 0
      text: "Th\u1EBF D\u1EBF M\xE8n r\u1EEBng T\xE2y \u0111\u1EBFn \u0111\xE2y l\xE0m
        c\xE1i ch\xF3 g\xEC?"
      enableCameraFocus: 0
      cameraFocusTarget: {fileID: 0}
    - isPlayer: 0
      text: "Ta \u0111\u1EBFn \u0111\u1EC3 gi\u1EA3i c\u1EE9u ng\u01B0\u1EDDi b\u1EA1n
        c\u1EE7a ta. D\u1EBF Cho\u1EAFt."
      enableCameraFocus: 0
      cameraFocusTarget: {fileID: 0}
    - isPlayer: 0
      text: "\xC0~ c\xE1i con d\u1EBF n\xE2u n\xE2u, nh\u1ECF nh\u1ECF, tr\xF4ng
        nh\u01B0 \u0111\u1ED1ng\u2026"
      enableCameraFocus: 0
      cameraFocusTarget: {fileID: 0}
    - isPlayer: 0
      text: "\xC0 th\xF4i, n\xF3i v\u1EADy h\u01A1i th\xF4."
      enableCameraFocus: 0
      cameraFocusTarget: {fileID: 0}
    - isPlayer: 0
      text: "N\xF3 \u0111ang n\u1EB1m tr\xEAn d\u0129a kia k\xECa."
      enableCameraFocus: 0
      cameraFocusTarget: {fileID: 0}
    - isPlayer: 0
      text: "Ng\u01B0\u01A1i\u2026 mang b\u1EA1n ta l\xEAn d\u0129a \u0111\u1EC3
        l\xE0m g\xEC!?"
      enableCameraFocus: 0
      cameraFocusTarget: {fileID: 0}
    - isPlayer: 0
      text: "\u0102n ch\u1EE9 l\xE0m g\xEC."
      enableCameraFocus: 0
      cameraFocusTarget: {fileID: 0}
    - isPlayer: 0
      text: "Th\u1ECBt d\u1EBF gi\xF2n, dai, b\u1ED5 d\u01B0\u1EE1ng, t\u1ED1t cho
        nhan s\u1EAFc n\u1EEF ho\xE0ng l\u1EAFm."
      enableCameraFocus: 0
      cameraFocusTarget: {fileID: 0}
    - isPlayer: 0
      text: "Ngon c\xE1i qu\u1EA7n qu\xE8!"
      enableCameraFocus: 0
      cameraFocusTarget: {fileID: 0}
    - isPlayer: 0
      text: "B\xE0 gi\xE0 mau th\u1EA3 b\u1EA1n ta ra ngay!"
      enableCameraFocus: 0
      cameraFocusTarget: {fileID: 0}
    - isPlayer: 0
      text: "TA \u0110\xC3 B\u1EA2O TA KH\xD4NG PH\u1EA2I B\xC0 GI\xC0!!!"
      enableCameraFocus: 0
      cameraFocusTarget: {fileID: 0}
    - isPlayer: 0
      text: "Ng\u01B0\u01A1i \u0111\xFAng l\xE0 th\u1EB1ng \u0111\u1EA7u khu\u1EA5t,
        m\u1ED3m m\xE9p v\xF4 gi\xE1o d\u1EE5c!"
      enableCameraFocus: 0
      cameraFocusTarget: {fileID: 0}
    - isPlayer: 0
      text: "\u2026"
      enableCameraFocus: 0
      cameraFocusTarget: {fileID: 0}
    - isPlayer: 1
      text: "Th\u1EBF gi\u1EDD b\xE0\u2026 \xE0 nh\u1EA7m\u2026 n\u1EEF ho\xE0ng
        \u0111\u1ECBnh sao?"
      enableCameraFocus: 0
      cameraFocusTarget: {fileID: 0}
    - isPlayer: 0
      text: "R\u1EA5t \u0111\u01A1n gi\u1EA3n."
      enableCameraFocus: 0
      cameraFocusTarget: {fileID: 0}
    - isPlayer: 0
      text: "Qu\u1EF3 xu\u1ED1ng xin l\u1ED7i, ho\u1EB7c rap cho ta nghe r\u1ED3i
        ta s\u1EBD c\xE2n nh\u1EAFc\u2026"
      enableCameraFocus: 0
      cameraFocusTarget: {fileID: 0}
    - isPlayer: 0
      text: "C\xF2n kh\xF4ng th\xEC \u0111\u1EC3 ta d\u1EA1y ng\u01B0\u01A1i bi\u1EBFt."
      enableCameraFocus: 0
      cameraFocusTarget: {fileID: 0}
    - isPlayer: 0
      text: "AI M\u1EDAI L\xC0 K\u1EBA CAI TR\u1ECA \u1EDE \u0110\xC2Y!"
      enableCameraFocus: 0
      cameraFocusTarget: {fileID: 0}
  outroDialogue:
    playerSprite: {fileID: 5945871790718036829, guid: ae04c40ca785d07499f40f828afaf685,
      type: 3}
    npcSprite: {fileID: 3486365374980857469, guid: 723062f81455a4243aeaf0a042f53827,
      type: 3}
    lines:
    - isPlayer: 0
      text: "Khoan\u2026 khoan \u0111\xE3!"
      enableCameraFocus: 0
      cameraFocusTarget: {fileID: 0}
    - isPlayer: 0
      text: "\u0110\u1EE7 r\u1ED3i! \u0110\u1EE7 r\u1ED3i!"
      enableCameraFocus: 0
      cameraFocusTarget: {fileID: 0}
    - isPlayer: 1
      text: Sao?
      enableCameraFocus: 0
      cameraFocusTarget: {fileID: 0}
    - isPlayer: 1
      text: "N\xE3y c\xF2n \u0111\xF2i \u0103n b\u1EA1n ta c\u01A1 m\xE0?"
      enableCameraFocus: 0
      cameraFocusTarget: {fileID: 0}
    - isPlayer: 0
      text: "Ta\u2026 ta th\u1EEBa nh\u1EADn."
      enableCameraFocus: 0
      cameraFocusTarget: {fileID: 0}
    - isPlayer: 0
      text: "Ng\u01B0\u01A1i m\u1EA1nh h\u01A1n ta t\u01B0\u1EDFng."
      enableCameraFocus: 0
      cameraFocusTarget: {fileID: 0}
    - isPlayer: 0
      text: "Th\u1EA3 con d\u1EBF kia ra!"
      enableCameraFocus: 0
      cameraFocusTarget: {fileID: 0}
  bossSpawner: {fileID: 2184686802394060048}
