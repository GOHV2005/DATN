--- !u!1001 &1683778768
PrefabInstance:
  m_ObjectHideFlags: 0
  serializedVersion: 2
  m_Modification:
    serializedVersion: 3
    m_TransformParent: {fileID: 0}
    m_Modifications:
    - target: {fileID: 1453108101841570273, guid: 9cf2c0a77ce34aa4e879f7299f80016c,
        type: 3}
      propertyPath: playerTransform
      value: 
      objectReference: {fileID: 467137236}
    - target: {fileID: 1453108101841570273, guid: 9cf2c0a77ce34aa4e879f7299f80016c,
        type: 3}
      propertyPath: questDescription
      value: "Th\u01B0\u01A1ng nh\xE2n c\u1EA7n l\xE1 c\u1ECF \u0111\u1EC3 trao \u0111\u1ED5i
        l\xF2ng \u0111\xE8n"
      objectReference: {fileID: 0}
    - target: {fileID: 1453108101841570273, guid: 9cf2c0a77ce34aa4e879f7299f80016c,
        type: 3}
      propertyPath: rewardItemPrefab
      value: 
      objectReference: {fileID: 671203211820296829, guid: 56968a826248b45489b458397de1f840,
        type: 3}
    - target: {fileID: 1453108101841570273, guid: 9cf2c0a77ce34aa4e879f7299f80016c,
        type: 3}
      propertyPath: requiredItems.Array.size
      value: 1
      objectReference: {fileID: 0}
    - target: {fileID: 1453108101841570273, guid: 9cf2c0a77ce34aa4e879f7299f80016c,
        type: 3}
      propertyPath: fullDialogue.playerSprite
      value: 
      objectReference: {fileID: -7689763433968391079, guid: 05b6eb43be472914381af94b2db7f9b3,
        type: 3}
    - target: {fileID: 1453108101841570273, guid: 9cf2c0a77ce34aa4e879f7299f80016c,
        type: 3}
      propertyPath: 'requiredItems.Array.data[0]'
      value: "c\u1ECF"
      objectReference: {fileID: 0}
    - target: {fileID: 1453108101841570273, guid: 9cf2c0a77ce34aa4e879f7299f80016c,
        type: 3}
      propertyPath: fullDialogue.lines.Array.data[0].text
      value: "Xin ch\xE0o th\u01B0\u01A1ng nh\xE2n lang thang"
      objectReference: {fileID: 0}
    - target: {fileID: 1453108101841570273, guid: 9cf2c0a77ce34aa4e879f7299f80016c,
        type: 3}
      propertyPath: fullDialogue.lines.Array.data[1].text
      value: "ch\xE0o d\u1EBF m\xE8n"
      objectReference: {fileID: 0}
    - target: {fileID: 1453108101841570273, guid: 9cf2c0a77ce34aa4e879f7299f80016c,
        type: 3}
      propertyPath: fullDialogue.lines.Array.data[2].text
      value: "Ng\xE0i c\xF3 th\u1EC3 cho ta 1 c\xE2y \u0111\xE8n \u0111\u01B0\u1EE3c
        kh\xF4ng"
      objectReference: {fileID: 0}
    - target: {fileID: 1453108101841570273, guid: 9cf2c0a77ce34aa4e879f7299f80016c,
        type: 3}
      propertyPath: fullDialogue.lines.Array.data[3].text
      value: "\u0110\u01B0\u1EE3c, n\u1EBFu ng\u01B0\u1EDDi \u0111em cho ta l\xE1
        c\u1ECF n\xF3 l\xE0 1 l\xE1 c\u1ECF r\u1EA5t \u0111\u1EB7c bi\u1EC7t m\xE0u
        c\u1EE7a n\xF3 kh\xE1c v\u1EDBi c\u1ECF xung quanh n\xF3 li\u1EC7u ng\u01B0\u01A1i
        d\xE1m?"
      objectReference: {fileID: 0}
    - target: {fileID: 1453108101841570273, guid: 9cf2c0a77ce34aa4e879f7299f80016c,
        type: 3}
      propertyPath: fullDialogue.lines.Array.data[4].text
      value: "Ch\xFAc may m\u1EAFn"
      objectReference: {fileID: 0}
    - target: {fileID: 1453108101841570273, guid: 9cf2c0a77ce34aa4e879f7299f80016c,
        type: 3}
      propertyPath: fullDialogue.lines.Array.data[5].text
      value: "T\xF9y ng\u01B0\u01A1i ng\u01B0ng \u1EDF d\u01B0\u1EDBi \u0111\u1EA5y
        t\u1ED1i l\u1EAFm \u0111\u1EA5y\n"
      objectReference: {fileID: 0}
    - target: {fileID: 1453108101841570273, guid: 9cf2c0a77ce34aa4e879f7299f80016c,
        type: 3}
      propertyPath: fullDialogue.lines.Array.data[6].text
      value: "C\u1ECF c\u1EE7a ta \u0111\xE2u"
      objectReference: {fileID: 0}
    - target: {fileID: 1453108101841570273, guid: 9cf2c0a77ce34aa4e879f7299f80016c,
        type: 3}
      propertyPath: fullDialogue.lines.Array.data[7].text
      value: "L\xF2ng \u0111\xE8n c\u1EE7a ng\u01B0\u01A1i \u0111\xE2y xong r\u1ED3i
        th\xEC \u0111i \u0111i"
      objectReference: {fileID: 0}
    - target: {fileID: 1453108101841570273, guid: 9cf2c0a77ce34aa4e879f7299f80016c,
        type: 3}
      propertyPath: fullDialogue.lines.Array.data[8].text
      value: "Ng\u01B0\u01A1i quay l\u1EA1i l\xE0m g\xEC b\u1ED9 ng\u01B0\u01A1i
        l\xE0m r\u1EDBt g\xEC \xE0?"
      objectReference: {fileID: 0}
    - target: {fileID: 3705517308972320440, guid: 9cf2c0a77ce34aa4e879f7299f80016c,
        type: 3}
      propertyPath: m_Name
      value: Npc
      objectReference: {fileID: 0}
